# ── СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env И ЗАПОЛНИТЕ ──

# MySQL база данных
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ваш_пароль_mysql
DB_NAME=tuyona_db

# JWT секрет (придумайте любую длинную строку)
JWT_SECRET=tuyona_super_secret_key_2025_change_this

# Сервер
PORT=3000
NODE_ENV=development

# Папка для загруженных фото
UPLOAD_DIR=public/uploads
